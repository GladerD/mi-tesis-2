
\ProvidesPackage{beamerthemeUASLP1}[2016/12/06]

% Define colors
\definecolor{UASLPGrey}{RGB}{218,218,218}
\definecolor{UASLPBlue}{RGB}{9,46,83}

% Outer theme with sides
\useoutertheme[width=.12\paperwidth]{sidebar}

% Define height of head regular frames
\setlength{\beamer@headheight}{.15\paperheight}
%Declare Images
% Image for top-left regular frame
\pgfdeclareimage[width=.12\paperwidth]{small-logo}{udg_color.png}
%Image for title frame
\pgfdeclareimage[width=.38\paperwidth]{type-logo}{udg_cucei_color.png}
%Image for final frame
\pgfdeclareimage[width=.33\paperwidth]{white-logo}{udg_blanco.png}
% Image for bottom-right title frame
\pgfdeclareimage[width=.25\paperwidth]{large-corner}{large-corner}
%Image for top-right regular frame
\pgfdeclareimage[height=\beamer@headheight]{small-corner}{small-corner}

% Declare sidebar navigation for regular frames
\setbeamertemplate{sidebar left}{%
\vskip 5pt
\insertverticalnavigation{\beamer@sidebarwidth}%
}

% Declare foot line for regular frame
\setbeamertemplate{footline}[text line]{%
  \begin{beamercolorbox}[wd=\paperwidth,sep=9pt,left]{footline}
    \textit{Maestría en Ciencias de Ingeniería Eléctrica}
  \end{beamercolorbox}
}

%% Declare regular frame title and side
\addtobeamertemplate{frametitle}{}{%
\begin{pgfpicture}
\pgf@relevantforpicturesizefalse
\pgftransformxshift{-\Gm@lmargin}
\pgftransformyshift{\beamer@headheight+18pt}
% Image at top-right
\pgftext[at=\pgfpoint{\paperwidth}{-\beamer@headheight},right,base]{\pgfuseimage{small-corner}}
% Line between logo space and title
\pgfpathmoveto{\pgfpoint{.12\paperwidth}{0pt}}
\pgfpathlineto{\pgfpoint{.12\paperwidth}{-\beamer@headheight}}
\pgfsetlinewidth{3pt}
\pgfsetinnerlinewidth{1pt}
\pgfsetinnerstrokecolor{UASLPBlue!70}
\pgfsetcolor{white}
\pgfusepath{stroke}
% Line between frame content and navigation
\pgfpathmoveto{\pgfpoint{.12\paperwidth}{-.18\paperheight}}
\pgfpathlineto{\pgfpoint{.12\paperwidth}{-.97\paperheight}}
\pgfsetlinewidth{1pt}
\pgfsetinnerlinewidth{0pt}
\pgfsetcolor{UASLPBlue}
\pgfusepath{stroke}
% Image on top-left
\pgftext[at=\pgfpoint{.06\paperwidth}{-.16\paperheight},center,base]{\pgfuseimage{small-logo}}
% Image on bottom-left
%\pgftext[at=\pgfpoint{.05\paperwidth}{-.97\paperheight},center,base]{\pgfuseimage{small-logo1}}
\end{pgfpicture}%
\vskip-25pt%
}

\addtobeamertemplate{title page}{%
\usebeamertemplate{title background}%
\vskip .1\paperheight%
}
{}

%% Title template background
\newcommand\DoPurpleBackground{%
\pgfpathmoveto{\pgfpointorigin}
\pgfpathrectanglecorners{\pgfpoint{0pt}{0pt}}{\pgfpoint{\paperwidth}{-\paperheight}}
% Background color
\pgfsetfillcolor{UASLPBlue}
\pgfusepath{fill}
% Large corner
\pgftext[at=\pgfpoint{\paperwidth}{-\paperheight},right,base]{\pgfuseimage{large-corner}}
}

\setbeamertemplate{title background}{%
\begin{pgfpicture}
\pgf@relevantforpicturesizefalse
\pgftransformxshift{-\Gm@lmargin}
\pgftransformyshift{5.5pt}
\DoPurpleBackground

% White bar across top
\pgfpathmoveto{\pgfpointorigin}
\pgfpathrectanglecorners{\pgfpoint{0pt}{0pt}}{\pgfpoint{\paperwidth}{-.20\paperheight}}
\pgfsetfillcolor{white}
\pgfusepath{fill}

% Logo
\pgftext[at=\pgfpoint{.024\paperwidth}{-.15\paperheight},left,base]{\pgfuseimage{type-logo}}

% short bar on left
\pgfpathrectanglecorners{\pgfpoint{0pt}{-.17\paperheight}}{\pgfpoint{.1\paperwidth}{-.19\paperheight}}
\pgfsetfillcolor{UASLPBlue}
\pgfusepath{fill}

% Followed by long bar on right
\pgfpathrectanglecorners{\pgfpoint{.12\paperwidth}{-.17\paperheight}}{\pgfpoint{\paperwidth}{-.19\paperheight}}
\pgfsetfillcolor{UASLPGrey}
\pgfusepath{fill}

% A stroke down the middle
\pgfpathmoveto{\pgfpoint{.12\paperwidth}{-.21\paperheight}}
\pgfpathlineto{\pgfpoint{.12\paperwidth}{-.93\paperheight}}
\pgfsetlinewidth{1pt}
\pgfsetcolor{white}
\pgfusepath{stroke}

\pgftext[at=\pgfpoint{.15\paperwidth}{-.92\paperheight},left,base]{\tiny \textit{Maestría en Ciencias en Ingenieria Eléctrica}}
\pgftext[at=\pgfpoint{.65\paperwidth}{-.92\paperheight},left,base]{\tiny \today}
\end{pgfpicture}%
}


%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Inner Theme
%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\useinnertheme{rectangles}
\setbeamertemplate{navigation symbols}{}

\setlength{\leftmargini}{.5em}
\setlength{\leftmarginii}{1.0em}
\setlength{\leftmarginiii}{1.5em}
\setlength{\leftmarginiv}{2.0em}
\setlength{\leftmarginv}{2.5em}
\setlength{\leftmarginvi}{3.0em}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%
% Colours
%%%%%%%%%%%%%%%%%%%%%%%%%%%%
\usecolortheme{rose}
\setbeamercolor{title page}{fg=white}
\setbeamercolor{logo}{bg=UASLPGrey}
\setbeamercolor{frametitle}{fg=white,bg=UASLPBlue}
\setbeamercolor{section in sidebar}{fg=black,bg=UASLPGrey}
\setbeamercolor{subsection in sidebar}{fg=black,bg=UASLPGrey}
\setbeamerfont{section in sidebar}{series=\bfseries}
\setbeamercolor{block title}{bg=UASLPBlue!20!white,fg=UASLPBlue}
\setbeamercolor{block body}{bg=UASLPGrey!40!white}
\setbeamercolor{itemize item}{fg=UASLPBlue}
\setbeamercolor{structure}{fg=UASLPBlue!80}
\setbeamercolor{title}{fg=white}


\newcommand\ThankYouFrame{
\begin{frame}[plain,t]
\begin{pgfpicture}
\pgf@relevantforpicturesizefalse
\pgftransformxshift{-\Gm@lmargin}
\pgftransformyshift{5.5pt}
\DoPurpleBackground
\pgftext[at=\pgfpoint{.5\paperwidth}{-.5\paperheight},center,center]{\pgfuseimage{white-logo}}
\pgftext[at=\pgfpoint{.5\paperwidth}{-.2\paperheight},center,center]{\huge\textcolor{white}{Gracias!}}
\pgftext[at=\pgfpoint{.3\paperwidth}{-.9\paperheight},center,center]{\small\textcolor{white}{\insertshortauthor}}
\end{pgfpicture}
\end{frame}
}

